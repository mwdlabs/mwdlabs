# Hashed static assets — cache forever (content-addressed)
/static/js/*
  Cache-Control: public, max-age=31536000, immutable

/static/css/*
  Cache-Control: public, max-age=31536000, immutable

/static/media/*
  Cache-Control: public, max-age=31536000, immutable

# Images, fonts, downloads — cache 1 week
/images/*
  Cache-Control: public, max-age=604800

/docs/*
  Cache-Control: public, max-age=604800

/downloads/*
  Cache-Control: public, max-age=604800

# manifest.json and robots — cache 1 day
/manifest.json
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

# index.html — no cache (always fresh)
/
  Cache-Control: no-cache, no-store, must-revalidate
